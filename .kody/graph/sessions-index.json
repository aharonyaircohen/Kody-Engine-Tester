e ref — no fetch/update before push | Stages: taskify:completed, plan:completed, build:completed, verify:completed, review:completed, review-fix:completed, ship:failed","createdAt":"2026-04-10T16:17:53.227Z","wordCount":963,"positions":[0,7,14,21,29,34,50,59,68,85,94,108,115,122,134,144,148,153,160,166,173,181,189,197,205,210,221,234,247,254,260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"2698-260418-123920","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"convention\",\"text\":\"Middleware factories (create*Middleware) attach the underlying limiter instance as a property on the returned function (middleware.limiter = limiter) so tests can call mw.limiter.destroy() for cleanup\",\"scope\":\"src/middleware\"},{\"kind\":\"convention\",\"text\":\"Tests always use afterEach with vi.useRealTimers() to restore real timers after fake-timer tests, and call limiter?.destroy() on the instance under test.\",\"scope\":\"src/middleware\"},{\"kind\":\"convention\",\"text\":\"Fake timers (vi.useFakeTimers()) are called inside individual tests, not in a beforeEach — each test manages its own timer state independently.\",\"scope\":\"src/middleware\"},{\"kind\":\"gotcha\",\"text\":\"cleanupTimer.unref() must be called on setInterval cleanup timers so the Node process can exit even with an active interval.\",\"scope\":\"src/middleware/rateLimit.ts\"},{\"kind\":\"decision\",\"text\":\"New SimpleRateLimiter reuses the existing byIp helper from rate-limiter.ts via import r","createdAt":"2026-04-18T12:46:36.174Z","wordCount":1000,"positions":[2,10,18,31,38,51,58,69,80,87,99,110,121,129,143,159,168,178,189,199,208,211,221,226,229,237,251,261,269,273,288,295,308,315,321,328,332,347,350,369,377,382,389,395,400,406,417,422,431,448,457,463,471,479,483,498,505,518,525,530,538,541,562,569,576,587,594,603,621,626,638,642,648,654,671,679,683,698,705,714,721,734,742,750,760,772,780,787,794,799,811,816,829,836,848,856,860,871,881,888,895,906,913,917,935,946,955,960,972,977,985,988,992]},"ep_stage_diary_002":{"taskId":"2698-260418-123920","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"X-RateLimit-Reset header used retryAfterMs (relative duration) as an absolute timestamp; must divide by 1000 for seconds and add to Date.now()\",\"scope\":\"src/middleware/rateLimit.ts\"}]}","createdAt":"2026-04-18T12:49:32.121Z","wordCount":239,"positions":[2,10,19,32,39,48,57,67,73,80,85,99,108,124,133,144,149,159,168,180,187,192,200,208,212,223,233]},"ep_stage_diary_003":{"taskId":"2698-260418-123920","episodeId":"ep_stage_diary_003","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"X-RateLimit-Reset header expects an absolute Unix timestamp in ms (Date.now()), but retryAfterMs is a duration. Use Date.now() + retryAfterMs, not just retryAfterMs.\",\"scope\":\"src/middleware/rateLimit.ts:55\"},{\"kind\":\"convention\",\"text\":\"Middleware files live in src/middleware/ and co-located tests use the .test.ts suffix in the same directory.\",\"scope\":\"src/middleware\"},{\"kind\":\"convention\",\"text\":\"Follow the factory pattern: createXxxMiddleware(config) returning a NextResponse | undefined, with destroy() on the limiter for cleanup.\",\"scope\":\"src/middleware\"},{\"kind\":\"convention\",\"text\":\"Tests use afterEach with vi.useRealTimers() after timer-based tests and call limiter.destroy() for cleanup.\",\"scope\":\"src/middleware\"},{\"kind\":\"lesson\",\"text\":\"When adding a new file that overlaps with an existing one (rate-limiter vs rateLimit), name it distinctly and mirror the existing patterns to avoid reviewers second-guessing intent.\",\"s","createdAt":"2026-04-18T12:53:53.851Z","wordCount":1000,"positions":[2,10,17,23,36,43,52,61,71,77,84,95,104,109,122,126,131,143,161,171,175,180,188,202,206,211,227,235,239,250,260,263,270,277,290,297,308,314,322,326,342,345,353,359,368,373,376,390,395,408,416,420,435,442,455,462,473,481,490,510,518,530,545,561,578,590,601,609,613,628,635,648,655,661,665,680,683,699,705,711,717,727,732,740,754,765,773,777,792,799,808,820,829,833,843,860,869,874,879,887,890,902,910,925,936,945,957,963,973,980,989]},"ep_stage_diary_004":{"taskId":"2698-260418-123920","episodeId":"ep_stage_diary_004","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"IP blacklist/whitelist precedence: check blacklist BEFORE whitelist, not after. Existing rate-limiter.ts does this correctly, new code inverted the order.\",\"scope\":\"src/middleware/rateLimit.ts\"},{\"kind\":\"convention\",\"text\":\"Middleware factory pattern (create*Middleware) + limiter class with destroy() cleanup is the established convention in this codebase.\",\"scope\":\"src/middleware/rateLimiter.ts\"},{\"kind\":\"lesson\",\"text\":\"X-RateLimit-Reset should be Unix seconds (integer), not milliseconds. Client-side Retry-After parsing depends on this.\",\"scope\":\"src/middleware/rateLimit.ts\"},{\"kind\":\"convention\",\"text\":\"Tests co-located with source (rateLimit.test.ts alongside rateLimit.ts), using vi.useRealTimers() in afterEach and NextRequest factory helper.\",\"scope\":\"src/middleware\"}]}","createdAt":"2026-04-18T12:54:28.713Z","wordCount":839,"positions":[2,10,19,32,39,48,55,58,68,78,90,96,106,113,124,128,135,144,149,157,170,181,185,190,203,212,220,224,235,245,252,259,272,279,290,298,307,314,328,336,347,357,372,384,403,415,423,427,438,450,457,464,473,482,492,508,513,522,532,536,550,557,562,568,574,582,601,609,613,624,634,641,648,661,668,674,677,690,698,708,713