16290731874155},"credentials":{"docCount":1,"idf":1.916290731874155},"enumeration":{"docCount":1,"idf":1.916290731874155},"attacks":{"docCount":1,"idf":1.916290731874155},"blocks":{"docCount":1,"idf":1.916290731874155},"swallow":{"docCount":1,"idf":1.916290731874155},"during":{"docCount":1,"idf":1.916290731874155},"post":{"docCount":1,"idf":1.916290731874155},"creation":{"docCount":1,"idf":1.916290731874155},"leaving":{"docCount":1,"idf":1.916290731874155},"orphaned":{"docCount":1,"idf":1.916290731874155},"records":{"docCount":1,"idf":1.916290731874155}},"documents":{"ep_ci_failure_001":{"taskId":"-Engine-Tester/actions/runs/24250536747))","episodeId":"ep_ci_failure_001","source":"ci_failure","content":"Task: -Engine-Tester/actions/runs/24250536747)) | Outcome: failed | Observation: The pipeline completed all stages except ship, which failed on git push due to stale remote state — another process updated main while this pipeline was running. The verify stage completed after 1 retry but produced typecheck errors in the report, suggesting the retry may have passed without properly resolving the underlying TypeScript type mismatches in PagesPageConfig validation. | Failed at: ship | Suggestion: Add a `git fetch origin main` step before the ship stage's force-push to ensure the local ref is up-to-date with remote, and investigate whether the verify stage's retry logic is properly re-running type checks rather than passing cached results. | Flaw: ship — Git push rejected due to stale remote ref — no fetch/update before push | Stages: taskify:completed, plan:completed, build:completed, verify:completed, review:completed, review-fix:completed, ship:failed","createdAt":"2026-04-10T16:17:53.227Z","wordCount":963,"positions":[0,7,14,21,29,34,50,59,68,85,94,108,115,122,134,144,148,153,160,166,173,181,189,197,205,210,221,234,247,254,260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"approve`","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"When a multi-step operation's first step succeeds (user created) but second fails (login), the catch block must not reuse the second error's status/code—it should prefer the first step's outcome or a \",\"scope\":\"src/app/api/auth/register\"},{\"kind\":\"gotcha\",\"text\":\"Bare `catch {}` that silently swallows payload.delete() failures masks cleanup errors; the outer catch then reports the wrong error and status.\",\"scope\":\"src/app/api/auth/register\"},{\"kind\":\"lesson\",\"text\":\"Checking email existence then creating a user is a TOCTOU race; duplicate inserts will throw a DB-level error, not the intended 409, unless uniqueness is enforced at the schema level before the insert\",\"scope\":\"auth/register\"},{\"kind\":\"convention\",\"text\":\"Return early after a failed `payload.delete()` in error-recovery cleanup rather than continuing to re-throw, so the user isn't created twice on retry.\",\"scope\":\"src/app/api/auth/register\"}]}","createdAt":"2026-04-18T17:08:54.029Z","wordCount":972,"positions":[2,10,19,32,39,48,62,68,73,85,91,96,106,111,124,131,138,150,156,162,167,171,181,188,196,203,218,229,235,242,258,266,270,274,278,283,296,303,312,319,325,340,349,358,366,375,384,390,398,410,416,427,439,445,455,465,473,477,481,485,490,503,510,519,526,535,541,556,567,577,584,590,600,613,621,624,630,637,645,654,659,666,680,696,703,709,720,729,737,742,755,762,775,782,789,795,803,811,819,832,838,847,855,862,867,881,884,891,898,903,909,917,926,935,943,947,951,955,960]},"ep_stage_diary_002":{"taskId":"approve`","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"After creating a user, always catch DB/persistence errors separately from auth errors; conflating them overwrites the correct status code (e.g., turning 401 auth failures into 500).\",\"scope\":\"src/app/api/auth/register/route.ts\"}]}","createdAt":"2026-04-18T17:12:39.392Z","wordCount":289,"positions":[2,10,17,23,36,43,52,59,65,76,82,89,95,98,110,117,133,138,146,162,177,185,192,204,212,216,221,230,235,243,251,255,259,263,268,277,283]},"ep_stage_diary_003":{"taskId":"approve`","episodeId":"ep_stage_diary_003","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"lesson\",\"text\":\"Use DB-level unique constraints (e.g., Payload's `unique: true`) rather than application-level checks to prevent duplicate emails, avoiding TOCTOU races.\",\"scope\":\"auth\"},{\"kind\":\"convention\",\"text\":\"Return generic error messages (e.g., 'Invalid credentials') for all auth failures to prevent user enumeration attacks.\",\"scope\":\"auth\"},{\"kind\":\"gotcha\",\"text\":\"Bare `catch {}` blocks silently swallow `payload.delete()` failures during post-creation error cleanup, leaving orphaned user records.\",\"scope\":\"src/app/api/auth/register/route.ts\"}]}","createdAt":"2026-04-18T17:14:22.400Z","wordCount":599,"positions":[2,10,19,32,39,48,55,59,62,68,75,94,105,113,120,127,132,144,150,160,168,178,186,195,202,211,219,228,235,248,255,262,270,276,293,301,323,328,340,348,353,365,376,384,393,400,409,416,422,432,439,448,457,465,475,484,491,496,505,511,520,528,537,542,553,561,565,569,573,578,587,593]}},"totalDocs":4}