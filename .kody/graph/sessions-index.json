[0,7,14,21,29,34,50,59,68,85,94,108,115,122,134,144,148,153,160,166,173,181,189,197,205,210,221,234,247,254,260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"2793-260418-164941","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The test file passed all 15 tests but had 13 lint errors, causing FAIL verification — always run lint checks before marking a stage done.\",\"scope\":\"tests/int/auth-protected-routes.int.spec.ts\"},{\"kind\":\"gotcha\",\"text\":\"`as any` on mockPayload bypasses type checking in stubs — prefer explicit interface types for mock objects to catch contract mismatches early.\",\"scope\":\"src/auth/AuthService\"},{\"kind\":\"lesson\",\"text\":\"Co-located unit test (src/auth/withAuth.test.ts) was planned but never created — track sub-deliverables explicitly to avoid incomplete implementations.\",\"scope\":\"test planning\"},{\"kind\":\"lesson\",\"text\":\"Pre-existing typecheck errors in api.int.spec.ts surfaced during this stage — unrelated failures can block review even when your changeset is correct.\",\"scope\":\"CI review\"}]}","createdAt":"2026-04-18T18:02:57.256Z","wordCount":852,"positions":[2,10,19,32,39,48,59,64,69,80,83,97,100,105,113,121,126,141,148,152,157,164,171,181,187,195,203,209,213,218,228,235,239,244,251,258,267,278,286,298,307,312,324,332,339,348,358,368,373,384,390,399,410,419,427,431,436,452,459,468,475,478,486,491,497,501,506,515,520,528,540,546,556,562,566,579,593,599,610,629,637,642,655,662,671,678,682,691,701,711,715,719,724,727,736,748,756,766,779,785,792,802,807,820,831,839,842]},"ep_stage_diary_002":{"taskId":"2793-260418-164941","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"lesson\",\"text\":\"New integration test files must pass linting before the task is considered complete — lint errors count as failures in review.\",\"scope\":\"tests/int\"},{\"kind\":\"lesson\",\"text\":\"When a unit test file is planned (e.g. withAuth.test.ts) but not created, the task is not done even if integration tests pass.\",\"scope\":\"auth\"},{\"kind\":\"gotcha\",\"text\":\"Pre-existing typecheck errors in other files can cause a task to fail review even if the new code is correct.\",\"scope\":\"typecheck\"},{\"kind\":\"convention\",\"text\":\"Integration test files live under tests/int/ and must co-exist with any planned unit tests in src/ to be considered complete.\",\"scope\":\"tests/int\"},{\"kind\":\"gotcha\",\"text\":\"Failing tests in tests/int/api.int.spec.ts that appear unrelated still cause review FAIL if the task modified files in the same directory.\",\"scope\":\"tests/int/api.int.spec.ts\"}]}","createdAt":"2026-04-18T18:22:48.208Z","wordCount":914,"positions":[2,10,17,23,36,43,52,59,63,75,80,86,91,96,104,115,123,134,145,150,157,166,178,188,196,202,210,217,226,240,245,250,258,272,281,286,294,298,311,319,323,328,336,348,354,362,370,379,386,395,402,406,415,425,435,441,451,459,467,472,479,491,495,503,514,522,536,543,556,563,575,580,586,591,597,603,612,617,620,631,635,643,648,657,668,679,691,699,705,713,720,729,736,744,753,759,763,767,771,776,784,791,801,807,813,820,832,837,846,859,864,877,885,891,895,899,903,908]},"ep_stage_diary_003":{"taskId":"2793-260418-164941","episodeId":"ep_stage_diary_003","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Error message strings must match exactly — a trailing period difference ('User not found.' vs 'User not found') causes assertion failures.\",\"scope\":\"src/auth\"},{\"kind\":\"gotcha\",\"text\":\"HTTP status codes must match the actual source — 403 returned for missing roles but tests asserted 401.\",\"scope\":\"src/auth\"},{\"kind\":\"lesson\",\"text\":\"When writing tests for existing HOCs, assert on the actual source code behavior (e.g., check createError calls in auth-service.ts) rather than inferring expected values.\",\"scope\":\"src/auth\"},{\"kind\":\"convention\",\"text\":\"withAuth returns 403 (Forbidden) for insufficient roles, not 401 (Unauthorized) — use 403 for role/permission checks.\",\"scope\":\"src/auth/withAuth.ts\"}]}","createdAt":"2026-04-18T18:26:31.748Z","wordCount":762,"positions":[2,10,19,32,39,48,55,61,69,77,82,88,100,109,116,129,134,138,146,150,155,159,167,174,184,196,204,208,217,224,233,240,245,252,258,263,273,280,289,293,306,314,324,330,339,346,354,358,367,374,383,395,403,413,422,428,442,449,456,461,477,483,495,504,509,517,521,528,533,543,552,562,570,574,583,590,603,610,619,627,632,647,660,667,671,676,692,696,704,709,720,730,738,742,747,756]},"ep_stage_diary_004":{"taskId":"2793-260418-164941","episodeId":"ep_stage_diary_004","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"When mocking `@/getPayload`, test assertions for error messages and HTTP status codes must match the actual response strings/codes in the source exactly—test failures here reveal real mismatches, not \",\"scope\":\"src/auth/withAuth.test.ts\"},{\"kind\":\"convention\",\"text\":\"Auth HOC tests are split into a unit file (`src/auth/withAuth.test.ts`) and an integration file (`tests/int/auth-protected-routes.int.spec.ts`).\",\"scope\":\"testing\"},{\"kind\":\"lesson\",\"text\":\"Error message assertions in tests (e.g., `'No token provided'`) must exactly match the string returned by the HOC; discrepancies are caught as test failures indicating source/test drift.\",\"scope\":\"testing\"}]}","createdAt":"2026-04-18T18:35:37.692Z","wordCount":725,"positions":[2,10,17,23,36,43,52,64,75,88,93,108,114,127,132,139,145,150,160,167,176,184,197,204,212,217,226,231,238,243,255,262,270,274,279,288,293,300,307,320,327,332,336,346,352,359,364,371,375,380,389,394,406,418,425,431,435,440,450,457,461,466,474,482,494,501,510,517,523,531,545,560,563,569,581,586,594,604,611,627,632,650,660,665,674,685,692,697,706,714]},"ep_stage_diary_005":{"taskId":"2793-260418-164941","episodeId":"ep_stage_diary_005","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"withAuth catch block uses `authContext.status ?? 401`, silently coercing any thrown status to 401 even when the underlying service threw a different code.\",\"scope\":\"src/auth/withAuth.ts\"},{\"kind\":\"lesson\",\"text\":\"Complete auth flow coverage requires both unit tests (HOC 401/403/200 behavior, role inheritance, optional token mode) and integration tests (register→login→protected route→refresh→logout).\",\"scope\":\"auth testing\"},{\"kind\":\"convention\",\"text\":\"Use `makeAuthenticatedContext()` helper to create user+tokens+sessions for test context, consistent across all auth test files.\",\"scope\":\"auth testing\"},{\"kind\":\"convention\",\"text\":\"Use `vi.mock('@/getPayload')` to mock Payload instance for AuthService unit tests.\",\"scope\":\"auth testing\"},{\"kind\":\"decision\",\"text\":\"Integration tests under `tests/int/` (not `src/`) for end-to-end auth flow; unit tests under `src/auth/` next to the module they test.\",\"scope\":\"auth testing\"}]}","createdAt":"2026-04-18T18:39:46.015Z","wordCount":990,"positions":[2,10,19,32,39,48,55,64,70,76,82,94,104,110,119,128,132,139,149,153,167,178,186,194,204,212,220,224,229,238,245,252,261,268,277,282,287,296,305,310,315,322,326,330,334,338,348,353,366,375,381,391,403,410,419,425,435,441,449,460,468,473,485,492,505,512,517,545,555,562,567,574,587,592,601,612,623,628,633,642,650,655,667,674,687,694,699,702,710,727,732,740,753,765,770,779,787,792,804,811,822,829,841,847,854,860,867,872,883,890,894,899,905,910,916,923,927,934,946,958,966,974,979]}},"totalDocs":6}