134,144,148,153,160,166,173,181,189,197,205,210,221,234,247,254,260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"approve`","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"decision\",\"text\":\"getAuthService() was a private module-level singleton in withAuth.ts — had to export it for route handler reuse\",\"scope\":\"src/auth\"},{\"kind\":\"convention\",\"text\":\"Route handlers return new Response(JSON.stringify(...), {status, headers}) — no framework wrappers, pure Next.js Response\",\"scope\":\"src/app/api\"},{\"kind\":\"gotcha\",\"text\":\"AuthService.login() throws {message, status} errors; catch err.status to set HTTP response — no Result type needed at route boundary\",\"scope\":\"src/auth\"},{\"kind\":\"convention\",\"text\":\"Test files are co-located next to route files as *.test.ts, using vi.useFakeTimers() and NextRequest construction\",\"scope\":\"src/app/api\"},{\"kind\":\"convention\",\"text\":\"CORS headers are present on other routes and should be included on new auth routes for consistency\",\"scope\":\"src/app/api\"}]}","createdAt":"2026-04-18T12:59:31.367Z","wordCount":863,"positions":[2,10,18,31,38,49,56,79,87,94,100,113,122,134,148,154,162,170,178,182,191,198,211,218,224,233,240,244,253,258,275,283,295,298,308,318,323,328,331,342,350,354,358,366,373,382,389,401,409,417,426,434,442,448,452,462,466,471,482,485,492,497,507,513,524,532,536,545,552,565,572,577,587,590,598,606,612,623,628,632,638,641,661,673,688,696,700,704,712,719,732,739,744,756,767,773,794,806,810,815,826,840,848,852,856]},"ep_stage_diary_002":{"taskId":"approve`","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"convention\",\"text\":\"Reuse `getAuthService()` singleton from `withAuth.ts` instead of instantiating `JwtService` directly — it manages the singleton lifecycle.\",\"scope\":\"auth\"},{\"kind\":\"gotcha\",\"text\":\"`Access-Control-Allow-Origin: *` in the OPTIONS handler conflicts with the same-origin default used elsewhere in the codebase.\",\"scope\":\"src/app/api\"},{\"kind\":\"convention\",\"text\":\"Co-located `*.test.ts` next to `route.ts` using `vi.useFakeTimers()` and `NextRequest` is the established test pattern here.\",\"scope\":\"testing\"},{\"kind\":\"decision\",\"text\":\"Routing through `AuthService.login()` (PBKDF2/Payload) vs old `src/api/auth/login.ts` (SHA-256/UserStore) intentionally avoids dual-auth anti-pattern.\",\"scope\":\"auth\"},{\"kind\":\"lesson\",\"text\":\"Old `src/api/auth/login.ts` utility was intentionally left untouched since the task scope only covered adding the new route handler.\",\"scope\":\"auth\"}]}","createdAt":"2026-04-18T13:03:59.021Z","wordCount":936,"positions":[2,10,19,32,39,52,59,66,84,100,109,113,124,139,151,165,177,187,200,208,217,224,233,241,248,256,262,280,288,296,315,320,327,335,340,357,369,377,381,385,393,400,413,420,423,434,439,443,452,458,462,469,472,494,514,526,531,539,547,555,567,574,585,592,600,609,621,631,638,647,650,655,659,663,668,674,679,683,687,698,712,719,724,729,734,745,753,762,769,778,785,790,794,798,803,809,813,825,839,844,854,864,869,875,880,888,899,903,909,920,928]}},"totalDocs":3}