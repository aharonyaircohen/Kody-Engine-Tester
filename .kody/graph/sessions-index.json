68","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"convention\",\"text\":\"Tests live co-located next to route files as route.test.ts, not in a separate __tests__ dir.\",\"scope\":\"testing\"},{\"kind\":\"convention\",\"text\":\"Response envelope is always { success, data } or { success: false, error: string } — never raw throw/catch.\",\"scope\":\"API routes\"},{\"kind\":\"lesson\",\"text\":\"When implementing a submit endpoint, validate existence first (404), then business rules (400), then duplicates (409), before creating (201). Order matters for correct error precedence.\",\"scope\":\"API routes\"}]}","createdAt":"2026-04-19T04:28:19.373Z","wordCount":566,"positions":[2,10,18,31,38,51,58,64,69,72,80,88,94,103,109,114,118,127,138,146,153,161,173,180,193,200,209,221,230,239,251,260,267,274,285,291,295,301,310,318,322,333,340,349,361,376,383,393,402,412,419,430,439,446,457,469,475,482,492,498,504,516,524,530,544,552,556]},"ep_stage_diary_002":{"taskId":"-Engine-Tester/pull/2868","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Accepting studentId from request body allows any authenticated student to impersonate another student — always use user.id from the authenticated session instead\",\"scope\":\"auth\"},{\"kind\":\"gotcha\",\"text\":\"A check-then-insert pattern (find duplicate, then create) has a race condition window where concurrent requests can both pass the check and insert duplicates\",\"scope\":\"src/app/api/assignments/[id]/submit\"},{\"kind\":\"convention\",\"text\":\"Use withAuth middleware to gate endpoints and extract user.id from the authenticated context — never trust client-supplied identity fields\",\"scope\":\"auth\"},{\"kind\":\"lesson\",\"text\":\"Duplicate submission protection must use a database constraint or transaction, not a find-then-insert in two separate calls\",\"scope\":\"data integrity\"},{\"kind\":\"decision\",\"text\":\"The reference pattern for quiz submission (findByID validation + {success, data} response shape) is correct and should be replicated, but auth must","createdAt":"2026-04-19T04:31:20.152Z","wordCount":1000,"positions":[2,10,19,32,39,48,55,65,80,88,93,100,104,118,129,141,149,159,166,170,175,187,201,209,219,227,236,243,252,261,272,279,288,293,309,323,328,338,351,362,375,380,389,399,406,419,427,431,435,439,452,456,467,474,487,494,498,507,521,526,540,548,553,565,579,589,595,601,608,617,626,635,643,652,659,668,675,685,696,707,712,718,727,741,754,760,770,780,784,793,801,809,814,828,835,846,857,867,879,884,896,905,919,928,934,943,953,975,991,996]},"ep_stage_diary_003":{"taskId":"-Engine-Tester/pull/2868","episodeId":"ep_stage_diary_003","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The route accepts studentId from the request body and uses it directly, bypassing the authenticated user's identity — any student can impersonate another by passing a different studentId in the body.\",\"scope\":\"auth\"},{\"kind\":\"gotcha\",\"text\":\"A check-then-insert pattern (find duplicate then create) has a race condition: two concurrent requests can both pass the duplicate check and create two submissions.\",\"scope\":\"src/app/api/assignments/[id]/submit/route.ts\"},{\"kind\":\"lesson\",\"text\":\"The authenticated user identity must come from the session or token, never from client-supplied body parameters — body studentId should be ignored or validated against the auth identity.\",\"scope\":\"auth\"},{\"kind\":\"lesson\",\"text\":\"To prevent race-condition duplicate submissions, use a unique database constraint on (assignmentId, studentId) and handle the constraint violation error, rather than a check-then-insert pattern.\",\"scope\":\"src/app/api/assign","createdAt":"2026-04-19T04:37:47.445Z","wordCount":1000,"positions":[2,10,17,23,36,43,52,63,69,77,96,104,113,121,131,145,159,166,177,181,193,205,216,226,236,253,261,269,278,285,294,303,314,321,330,335,350,364,369,380,384,395,408,413,422,432,442,449,453,468,476,480,484,488,501,505,512,518,525,532,541,552,566,571,580,585,599,610,617,628,635,644,649,662,667,687,698,708,720,725,737,745,754,761,770,780,788,793,803,813,826,832,839,848,863,877,892,903,914,924,931,938,945,956,963,974,982,986,990,994]},"ep_stage_diary_004":{"taskId":"-Engine-Tester/pull/2868","episodeId":"ep_stage_diary_004","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"If a route returns 409 for duplicate submissions, the DB unique constraint must actually exist in the schema — code comments asserting it are not enough.\",\"scope\":\"Submissions schema\"},{\"kind\":\"decision\",\"text\":\"Quiz submit pattern (getPayload, withAuth, findByID, {success,data}/{success:false,error}) is the canonical reference for entity-submission endpoints in this codebase.\",\"scope\":\"API route patterns\"},{\"kind\":\"gotcha\",\"text\":\"For submission endpoints, always use user.id from the authenticated context (withAuth) rather than studentId from the request body to prevent auth bypass.\",\"scope\":\"auth/submission routes\"}]}","createdAt":"2026-04-19T04:39:09.921Z","wordCount":682,"positions":[2,10,19,32,39,48,60,66,74,82,92,109,112,119,130,135,144,157,166,171,180,197,201,211,219,231,242,249,260,267,272,279,288,300,310,321,329,336,344,350,365,375,389,396,407,425,437,445,449,455,468,475,484,495,506,517,524,528,533,545,559,568,578,585,590,609,617,625,633,638,648,656,661,672]},"ep_stage_diary_005":{"taskId":"-Engine-Tester/pull/2868","episodeId":"ep_stage_diary_005","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"409 duplicate-detection logic that relies on a DB unique constraint is fragile — if the constraint doesn't exist in the schema, concurrent submissions silently create duplicates. Always verify the con\",\"scope\":\"src/app/api/assignments/[id]/submit/route.ts\"},{\"kind\":\"lesson\",\"text\":\"studentId must come from the authenticated user context (user.id), never from the request body, to prevent auth bypass.\",\"scope\":\"auth\"},{\"kind\":\"convention\",\"text\":\"This codebase uses getPayload({ config: configPromise }) and withAuth middleware for API routes, not direct payload access.\",\"scope\":\"src/app/api\"},{\"kind\":\"convention\",\"text\":\"Success responses follow { success, data } shape; errors follow { success: false, error } — matching the quiz submit pattern.\",\"scope\":\"API responses\"}]}","createdAt":"2026-04-19T04:41:44.274Z","wordCount":838,"positions":[2,10,17,23,36,43,52,59,63,73,83,94,106,109,116,130,147,158,166,179,187,198,210,219,226,238,245,256,262,270,274,278,282,295,299,306,312,319,326,335,342,352,357,371,385,390,399,404,409,424,432,441,449,454,464,472,481,488,501,513,522,527,540,548,569,578,593,597,605,609,616,624,634,642,646,650,658,665,678,685,693,703,712,721,728,735,742,751,760,767,777,790,795,802,813,821,825]},"ep_stage_diary_006":{"taskId":"-Engine-Tester/pull/2868","episodeId":"ep_stage_diary_006","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Tests using PostgreSQL constraint names (e.g., 'submissions_assignment_student_unique') will break on different backends; abstract the error or mock generically.\",\"scope\":\"src/app/api/assignments/[id]/submit/route.test.ts\"},{\"kind\":\"decision\",\"text\":\"Duplicate submission detection is delegated to the DB unique constraint on (assignment, student) — no pre-check needed, race-safe by default.\",\"scope\":\"Submissions collection\"},{\"kind\":\"convention\",\"text\":\"Student-facing endpoints read user identity from withAuth context (user.id), never from the request body — body carries only business data.\",\"scope\":\"api routes\"},{\"kind\":\"convention\",\"text\":\"API responses follow { success, data } | { success: false, error } shape, mirroring the quiz submit reference pattern.\",\"scope\":\"api routes\"}]}","createdAt":"2026-04-19T04:43:48.838Z","wordCount":847,"positions":[2,10,19,32,39,48,55,61,67,78,89,103,115,126,134,148,157,167,177,190,199,204,219,227,231,235,239,252,256,263,269,274,281,288,299,306,316,327,340,357,360,367,382,394,405,408,412,418,426,431,439,450,458,470,485,492,505,512,520,527,537,542,547,561,570,579,584,589,604,612,619,624,632,637,646,654,662,666,677,684,697,704,708,718,727,736,747,756,763,771,778,792,797,804,814,825,833,837]}},"totalDocs":7}