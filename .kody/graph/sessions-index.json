:{"taskId":"2656-260418-100644","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Build stage completed with status 'completed' but zero source files were created on disk. Glob confirms no files at expected paths.\",\"scope\":\"src/utils, src/collections\"},{\"kind\":\"lesson\",\"text\":\"Verify actual file existence on disk rather than inferring success from a pipeline status field.\",\"scope\":\"pipeline\"},{\"kind\":\"lesson\",\"text\":\"A pipeline stage can report 'completed' without any actual work being done — always validate deliverables independently.\",\"scope\":\"pipeline\"}]}","createdAt":"2026-04-18T10:20:28.016Z","wordCount":537,"positions":[2,10,19,32,39,48,55,61,67,82,90,105,110,117,128,139,145,150,159,162,171,180,189,197,201,208,212,228,235,244,251,258,265,270,283,288,295,300,310,325,334,341,350,358,371,378,387,396,405,415,423,434,442,446,453,458,464,471,478,487,500,517,525]},"ep_stage_diary_002":{"taskId":"2656-260418-100644","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Build stage reported 'completed' with zero files created on disk. Never trust build status alone — verify actual file existence via Glob or fs reads.\",\"scope\":\"pipeline\"},{\"kind\":\"gotcha\",\"text\":\"The task directory contains only metadata; the referenced codebase paths (src/collections/, src/utils/, src/auth/) don't exist yet. Files must be created fresh, not modified.\",\"scope\":\"new-project-setup\"},{\"kind\":\"lesson\",\"text\":\"When a stage shows status=completed but zero files exist, check whether the build step actually wrote to the correct working directory vs a stale/empty directory.\",\"scope\":\"pipeline\"}]}","createdAt":"2026-04-18T10:21:57.806Z","wordCount":670,"positions":[2,10,17,23,36,43,52,59,65,71,81,97,102,108,119,125,131,137,143,150,158,165,172,177,187,191,199,202,211,219,232,239,248,259,264,274,283,288,302,313,322,329,333,347,351,359,363,370,376,382,387,393,401,409,416,420,432,440,444,452,462,469,478,492,498,504,511,525,530,536,543,549,561,567,572,581,594,602,610,620,625,631,637,650,658]},"ep_stage_diary_003":{"taskId":"2656-260418-100644","episodeId":"ep_stage_diary_003","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The diff only contained infrastructure/task metadata but no source code files — review must verify both that files exist AND that they are actually in the diff.\",\"scope\":\"code review process\"}]}","createdAt":"2026-04-18T10:22:38.325Z","wordCount":249,"positions":[2,10,19,32,39,48,59,64,69,79,94,99,112,115,122,127,135,142,147,154,164,170,194,210,218,226,231,238]},"ep_stage_diary_004":{"taskId":"2656-260418-100644","episodeId":"ep_stage_diary_004","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The diff contained only task metadata files (`.kody/tasks/`), not the actual source code. Files must be created on disk, not just planned.\",\"scope\":\"implementation scope\"},{\"kind\":\"lesson\",\"text\":\"When Glob confirms 0 results for expected files like `src/utils/hash-password.ts`, the previous step did no real work — start fresh rather than trying to iterate on its output.\",\"scope\":\"task workflow\"}]}","createdAt":"2026-04-18T10:23:39.506Z","wordCount":460,"positions":[2,10,17,23,36,43,52,63,68,78,83,88,97,106,111,121,129,136,143,149,155,163,174,180,184,189,200,208,223,233,240,249,261,266,277,289,298,304,310,314,320,325,334,343,352,361,364,369,376,382,388,395,400,410,425,435,443,448]},"ep_stage_diary_005":{"taskId":"2656-260418-100644","episodeId":"ep_stage_diary_005","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The diff from HEAD~1 contained only metadata files and no source code changes. The required deliverables (hash-password utility, User Pay