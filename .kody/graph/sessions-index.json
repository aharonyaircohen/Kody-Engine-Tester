e_diary_001":{"taskId":"2711-260418-124338","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"convention\",\"text\":\"AuthService test pattern: mock @/getPayload, new JwtService('test-secret'), new AuthService(mockPayload, jwtService), vi.clearAllMocks() in beforeEach — apply to all auth endpoint tests.\",\"scope\":\"src/api/auth\"},{\"kind\":\"gotcha\",\"text\":\"login.ts was using UserStore SHA-256 while register.ts used AuthService PBKDF2 — these must be unified so Payload is the single auth source.\",\"scope\":\"src/api/auth/login.ts\"},{\"kind\":\"decision\",\"text\":\"login.ts becomes a thin wrapper; all user lookup, PBKDF2 verification (25000 iters), token gen, and refresh token storage live in AuthService.login().\",\"scope\":\"src/api/auth/login.ts\"},{\"kind\":\"decision\",\"text\":\"register.ts already delegates to authService.login() at line 69 — login.ts follows the same delegation pattern.\",\"scope\":\"src/api/auth/register.ts\"}]}","createdAt":"2026-04-18T13:10:40.296Z","wordCount":859,"positions":[2,10,18,31,38,51,58,70,75,84,91,103,107,119,124,134,138,150,163,176,179,198,211,224,229,238,247,255,259,263,272,279,288,295,301,308,314,324,328,332,338,347,350,355,367,382,390,398,401,416,423,428,438,446,450,454,459,465,472,479,490,497,503,506,516,521,534,539,547,554,568,574,582,588,597,605,611,619,627,639,650,658,662,666,671,677,684,691,702,709,718,721,729,742,754,765,770,775,781,784,796,801,812,823,831,835,839,844,853]},"ep_stage_diary_002":{"taskId":"2711-260418-124338","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"convention\",\"text\":\"Auth test files must follow exact pattern: mock @/getPayload, new JwtService(...), new AuthService(...), vi.clearAllMocks() in beforeEach\",\"scope\":\"src/api/auth\"},{\"kind\":\"gotcha\",\"text\":\"An endpoint that appears unchanged may still have been wrong — register.ts already delegated to authService but was overlooked\",\"scope\":\"src/api/auth/register.ts\"},{\"kind\":\"lesson\",\"text\":\"Consolidation work may reveal the target endpoint was already correct; scope the change to only what is actually broken\",\"scope\":\"src/api/auth/login.ts\"},{\"kind\":\"decision\",\"text\":\"Delegation pattern (service.login() call) is preferred over inline auth logic in route handlers\",\"scope\":\"src/api/auth\"},{\"kind\":\"gotcha\",\"text\":\"Dual auth anti-pattern: endpoints using different mechanisms (in-memory SHA-256 vs Payload PBKDF2) must be unified to one source\",\"scope\":\"auth\"}]}","createdAt":"2026-04-18T13:14:37.110Z","wordCount":910,"positions":[2,10,19,32,39,52,59,64,69,75,80,87,93,102,109,121,125,142,146,164,167,186,199,207,211,215,224,231,240,250,264,272,286,302,310,319,322,330,343,363,376,384,388,392,397,406,413,420,429,436,450,459,470,477,490,498,507,517,527,540,549,558,566,570,574,579,585,592,599,610,617,628,637,645,653,662,672,677,684,689,698,704,715,723,727,731,740,747,756,763,768,773,778,787,797,803,813,828,835,839,843,846,854,862,870,881,885,894,902]}},"totalDocs":3}