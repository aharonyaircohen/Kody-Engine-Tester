260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"2516-260418-040123","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The local status.json file may lag behind GitHub label state if the pipeline writes to GitHub before updating status.json — always use status.json to determine what SHOULD be present, and gh issue vie\",\"scope\":\".kody/tasks/2516-260418-040123/label-progression.test.ts\"},{\"kind\":\"convention\",\"text\":\"Lifecycle labels are mutually exclusive per stage (kody:planning, kody:building, etc.) — assert the current stage label is present AND future-stage labels are absent.\",\"scope\":\"kody pipeline labels\"},{\"kind\":\"convention\",\"text\":\"Complexity labels (kody:low/medium/high) persist across all pipeline stages and must be asserted as always-present throughout.\",\"scope\":\"kody pipeline labels\"},{\"kind\":\"lesson\",\"text\":\"The test reads current stage from status.json, not from the labels themselves — status.json is the source of truth for which stage label should be active.\",\"scope\":\"kody pipeline testing\"}]}","createdAt":"2026-04-18T04:11:15.736Z","wordCount":957,"positions":[2,10,18,31,38,47,58,64,71,76,85,89,96,103,109,122,131,141,148,155,164,171,178,185,189,196,204,229,242,245,251,257,266,271,277,282,289,296,302,314,319,326,333,346,353,363,374,383,393,397,404,409,419,424,434,442,453,461,467,476,488,495,501,512,522,530,535,544,555,562,575,582,593,601,606,610,617,623,631,642,651,662,670,682,689,697,711,719,724,733,744,751,760,771,776,782,790,801,808,814,827,834,847,854,866,876,892,898,914,924,932,937,946]},"ep_stage_diary_002":{"taskId":"2516-260418-040123","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Exiting plan mode without calling Write tool means zero code is produced. The build agent planned but never wrote the file.\",\"scope\":\"kody pipeline\"}]}","createdAt":"2026-04-18T04:13:16.130Z","wordCount":206,"positions":[2,10,19,32,39,48,55,63,68,73,81,89,95,100,106,111,119,133,139,145,157,163,173,181,189,194]},"ep_stage_diary_003":{"taskId":"2516-260418-040123","episodeId":"ep_stage_diary_003","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"An agent can exit plan mode without writing any code — plan success != implementation executed. Always verify the Write/Edit tool was actually called.\",\"scope\":\"agent execution\"},{\"kind\":\"gotcha\",\"text\":\"The review agent detects issues but does not write files. A fixup stage targeting a missing deliverable must do the implementation itself, not re-invoke the review agent.\",\"scope\":\"agent design\"},{\"kind\":\"lesson\",\"text\":\"Fix stages should create the missing deliverable (the test file) directly rather than re-running the agent that was supposed to produce it.\",\"scope\":\"pipeline design\"}]}","createdAt":"2026-04-18T04:18:08.909Z","wordCount":653,"positions":[2,10,17,23,36,43,52,62,72,77,82,87,95,103,107,114,119,130,145,155,162,173,179,184,193,202,212,220,226,240,247,256,267,274,280,288,304,308,314,323,329,335,347,355,367,379,394,402,406,409,420,427,436,444,450,461,468,477,484,488,502,513,521,538,543,549,558,565,570,573,585,600,612,626,634,643]},"ep_stage_diary_004":{"taskId":"2516-260418-040123","episodeId":"ep_stage_diary_004","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"Test stage names must not share the same label as their parent stage; 'review-fix' and 'review' both emit 'kody:review', causing false-positive failures when validating label removal.\",\"scope\":\"kody lifecycle labels\"},{\"kind\":\"lesson\",\"text\":\"When validating stage label removal, distinguish between 'label still present from current stage' vs 'label left over from a past stage'; the check must account for the label being legitimately re-add\",\"scope\":\"kody label-progression test\"},{\"kind\":\"convention\",\"text\":\"Kody lifecycle stages follow a strict sequence: planning → building → verifying → review → done; each stage adds its own label and removes the previous one.\",\"scope\":\"kody lifecycle\"}]}","createdAt":"2026-04-18T04:18:59.129Z","wordCount":753,"positions":[2,10,19,32,39,48,55,60,66,72,77,81,91,96,111,118,126,133,143,151,156,162,167,176,184,190,199,213,224,230,241,249,254,264,275,282,291,303,314,320,326,335,347,356,362,368,381,389,396,400,406,411,423,428,440,446,451,467,473,479,492,495,501,509,514,520,532,541,548,561,568,573,583,590,599,606,616,627,638,650,659,670,676,685,689,699,711,720,727,735,740]},"ep_stage_diary_005":{"taskId":"2516-260418-040123","episodeId":"ep_stage_diary_005","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"When stages share label names (e.g., 'review' and 'review-fix' both use 'kody:review'), the test must resolve the task ID from status.json rather than comparing label strings in isolation, otherwise p\",\"scope\":\"test logic\"}]}","createdAt":"2026-04-18T04:22:39.888Z","wordCount":284,"positions":[2,10,17,23,36,43,52,64,71,77,83,97,110,117,122,127,132,137,151,156,161,173,178,186,193,198,205,210,220,226,237,248,262,270,275]},"ep_stage_diary_006":{"taskId":"2516-260418-040123","episodeId":"ep_stage_diary_006","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"getGitHubLabels() splits on \\\\\\\\n, which breaks if any label contains whitespace or unusual characters; use a more robust parsing method.\",\"scope\":\"label-progression.test.ts\"}]}","createdAt":"2026-04-18T04:24:24.345Z","wordCount":232,"positions":[2,10,19,32,39,48,55,73,96,106,110,116,125,139,147,159,165,170,177,185,195,203,209,221,226]}},"totalDocs":7}