 have passed without properly resolving the underlying TypeScript type mismatches in PagesPageConfig validation. | Failed at: ship | Suggestion: Add a `git fetch origin main` step before the ship stage's force-push to ensure the local ref is up-to-date with remote, and investigate whether the verify stage's retry logic is properly re-running type checks rather than passing cached results. | Flaw: ship — Git push rejected due to stale remote ref — no fetch/update before push | Stages: taskify:completed, plan:completed, build:completed, verify:completed, review:completed, review-fix:completed, ship:failed","createdAt":"2026-04-10T16:17:53.227Z","wordCount":963,"positions":[0,7,14,21,29,34,50,59,68,85,94,108,115,122,134,144,148,153,160,166,173,181,189,197,205,210,221,234,247,254,260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"2791-260418-164939","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"convention\",\"text\":\"Sensitive fields use { hidden: true, access: { read: () => false, update: () => false } } — mirror this exactly for hash/salt.\",\"scope\":\"src/server/payload/collections/Users.ts\"},{\"kind\":\"lesson\",\"text\":\"beforeChange hooks auto-populate fields on write — same pattern used by displayName field for hash/salt population.\",\"scope\":\"src/server/payload/collections/Users.ts\"},{\"kind\":\"decision\",\"text\":\"PBKDF2 params (25000 iters, sha256, 512 bits) should be extracted to a shared utility to avoid duplication between the hook and AuthService verifyPassword.\",\"scope\":\"src/server/auth-service.ts\"},{\"kind\":\"convention\",\"text\":\"Co-located tests in Users.test.ts use findField() helper + makeMockReq() pattern — follow this for new field tests.\",\"scope\":\"src/server/payload/collections/Users.test.ts\"},{\"kind\":\"gotcha\",\"text\":\"Payload's built-in auth:true handles passwords internally but doesn't expose hash/salt to app code — explicit fields are ","createdAt":"2026-04-18T17:03:02.369Z","wordCount":1000,"positions":[2,10,18,31,38,51,58,68,75,81,89,95,105,117,124,138,150,162,174,179,187,195,199,206,214,226,232,239,246,255,262,275,281,286,295,305,313,318,326,334,346,356,361,366,380,388,392,399,407,419,425,432,439,450,457,464,472,478,485,493,497,513,528,535,546,552,564,576,585,597,615,623,627,634,639,647,654,661,674,681,684,692,701,707,712,715,719,731,740,754,764,780,784,790,799,807,811,818,826,838,844,849,856,863,872,879,889,898,903,908,916,926,941,949,956,961,969,973,980,989]},"ep_stage_diary_002":{"taskId":"2791-260418-164939","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"UserStore.verifyPassword() uses === for hash comparison, creating a timing-attack vulnerability. Always use crypto.timingSafeEqual for comparing secrets/hashes.\",\"scope\":\"src/auth/user-store.ts\"},{\"kind\":\"lesson\",\"text\":\"Fields that must be write-only for clients (like hash/salt) need both hidden:true and access:{read:()=>false,update:()=>false} — neither alone is sufficient.\",\"scope\":\"src/users/Users.ts\"},{\"kind\":\"convention\",\"text\":\"The codebase uses PBKDF2 with 25000 iterations, sha256, and 512-bit output for password hashing. Extract params to shared module before using.\",\"scope\":\"src/auth\"},{\"kind\":\"decision\",\"text\":\"Splitting password logic into a dedicated password-utils.ts module keeps AuthService clean and enables reuse across UserStore and other auth paths.\",\"scope\":\"src/auth/password-utils.ts\"}]}","createdAt":"2026-04-18T17:05:44.661Z","wordCount":873,"positions":[2,10,19,32,39,48,55,65,82,95,100,11