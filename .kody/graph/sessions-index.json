001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"decision\",\"text\":\"Test tasks for verify-gate improvements use single-file modifications to isolate gate filtering logic from broader task scope.\",\"scope\":\"kody-engine\"},{\"kind\":\"convention\",\"text\":\"Verify-gate validation runs trivial changes through full pipeline to confirm gates differentiate task-modified files from pre-existing errors in unrelated code.\",\"scope\":\"kody-engine\"},{\"kind\":\"gotcha\",\"text\":\"Build stage may report pre-existing TS/ESLint errors even if verify-gate is designed to skip them; gate behavior must be validated independently of build output.\",\"scope\":\"kody-engine\"}]}","createdAt":"2026-04-17T15:27:56.247Z","wordCount":633,"positions":[2,10,18,31,38,49,56,61,71,78,83,96,100,107,112,129,137,142,152,163,171,176,185,193,198,209,216,229,236,243,248,259,264,272,280,288,293,305,313,319,333,338,347,358,362,371,381,391,399,407,412,423,430,439,446,452,462,469,473,482,485,492,499,507,514,522,534,545,550,559,567,577,594,600,610,618,623]},"ep_stage_diary_002":{"taskId":"2275-260417-182600","episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"decision\",\"text\":\"Kody 0.3.2 verify-gate allows PRs to progress despite pre-existing TS/ESLint errors in unrelated files—this is intentional design.\",\"scope\":\"kody\"},{\"kind\":\"convention\",\"text\":\"'live-test' task type validates Kody engine improvements by running actual pipeline tasks with specific constraints.\",\"scope\":\"kody\"}]}","createdAt":"2026-04-17T15:36:36.766Z","wordCount":373,"positions":[2,10,17,23,36,43,54,61,72,79,84,91,98,107,115,119,128,131,138,148,158,172,184,194,202,211,218,231,239,244,250,255,260,270,275,282,298,306,313,322,333,342,357,365]}},"totalDocs":3}