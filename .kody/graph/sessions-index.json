9,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"decompose-2839-260418-203424","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"review\",\"insights\":[{\"kind\":\"gotcha\",\"text\":\"The guard checks `config.decompose?.enabled === false` (strict equality with boolean `false`). Undefined/null does NOT trigger fallback — the config must explicitly set `enabled: false`.\",\"scope\":\"feature flags\"},{\"kind\":\"convention\",\"text\":\"When adding a new top-level config section, include it in `kody.config.json` itself so the engine's own config is self-consistent and `config.decompose?.enabled` resolves at runtime.\",\"scope\":\"config\"},{\"kind\":\"lesson\",\"text\":\"The engine version (`@kody-ade/engine@0.4.4`) ships the guard already — the task only needed to populate the config key to make it operational, not implement the guard.\",\"scope\":\"engine integration\"},{\"kind\":\"decision\",\"text\":\"The feature flag is boolean — `enabled: false` means fallback, `enabled: true` (or absent with `=== false` check) means normal decompose behavior.\",\"scope\":\"feature flags\"}]}","createdAt":"2026-04-18T20:46:37.611Z","wordCount":925,"positions":[2,10,19,32,39,48,59,65,73,80,91,103,111,118,132,141,150,160,170,174,182,197,204,209,220,225,234,244,252,260,270,277,290,302,311,315,319,325,332,341,356,361,368,374,381,388,397,401,411,416,432,439,450,459,471,482,490,501,508,517,528,535,546,551,555,570,580,586,600,605,610,620,633,640,647,655,668,672,686,695,703,710,726,733,744,755,763,771,782,791,798,804,815,824,834,851,858,865,871,878,888,900,908,916]}},"totalDocs":2}