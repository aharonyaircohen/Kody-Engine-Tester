227Z","wordCount":963,"positions":[0,7,14,21,29,34,50,59,68,85,94,108,115,122,134,144,148,153,160,166,173,181,189,197,205,210,221,234,247,254,260,270,278,288,297,307,321,329,344,359,366,374,383,397,408,419,424,438,454,468,479,486,498,505,509,515,522,528,533,544,549,557,563,571,582,588,595,601,611,623,635,647,654,662,668,677,686,689,697,702,709,716,721,729,736,747,753,760,764,769,778,785,791,798,804,807,813,820,827,834,842,850,861,866,877,883,894,901,912,919,930,937,941,952,957]},"ep_stage_diary_001":{"taskId":"2505-260418-035537","episodeId":"ep_stage_diary_001","source":"stage_diary","content":"{\"stage\":\"build\",\"insights\":[{\"kind\":\"convention\",\"text\":\"Auth is enforced via `withAuth` HOC, not inline checks. Always use the HOC at the route level.\",\"scope\":\"src/app/api/\"},{\"kind\":\"gotcha\",\"text\":\"Landing page (`page.tsx`) may only do client-side auth checks without role enforcement — acceptable for public-facing entry points.\",\"scope\":\"src/app/\"},{\"kind\":\"gotcha\",\"text\":\"Frontend pages under `notes/*` may lack auth redirect UX even when API routes are protected; protect both layers independently.\",\"scope\":\"src/app/notes/\"},{\"kind\":\"lesson\",\"text\":\"Role enforcement (`withAuth({ roles: [...] })`) must be explicitly specified per route for instructor/admin pages — no inherited roles.\",\"scope\":\"auth\"},{\"kind\":\"decision\",\"text\":\"Two routes are intentionally public: `/health` and `/csrf-token` — these are explicitly excluded from auth coverage audits.\",\"scope\":\"auth\"}]}","createdAt":"2026-04-18T04:09:28.619Z","wordCount":883,"positions":[2,10,18,31,38,51,58,66,75,80,90,95,99,106,114,121,129,140,146,155,163,167,171,180,187,196,203,211,218,223,233,241,248,253,258,265,273,278,292,307,314,321,327,337,345,349,358,365,374,381,390,396,403,416,421,426,435,438,448,452,463,474,482,487,494,511,519,523,527,538,545,554,561,566,580,591,609,617,628,638,642,652,663,669,677,680,690,699,707,716,723,734,741,745,756,770,780,794,799,818,829,843,848,857,867,875]}},"totalDocs":2}