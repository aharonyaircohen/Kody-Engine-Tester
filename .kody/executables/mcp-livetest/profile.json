{
  "name": "mcp-livetest",
  "role": "primitive",
  "describe": "live test MCP",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to work on."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "maxTurnTimeoutSec": 1200,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "verifyAttempts": 4,
    "tools": [
      "Read",
      "Grep",
      "mcp__codegraph"
    ],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": [
      {
        "name": "codegraph",
        "command": "codegraph",
        "args": [
          "serve",
          "--mcp"
        ]
      }
    ]
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "loadIssueContext"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      },
      {
        "script": "postAgentComment"
      }
    ]
  }
}
