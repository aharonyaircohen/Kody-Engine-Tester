{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm tsc --noEmit",
    "lint": "pnpm lint",
    "lintFix": "",
    "formatFix": "",
    "testUnit": "pnpm test"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "agent": {
    "modelMap": {
      "cheap": "minimax/MiniMax-M2.7-highspeed",
      "mid": "minimax/MiniMax-M2.7-highspeed",
      "strong": "minimax/MiniMax-M2.7"
    },
    "budgets": {
      "taskify":    { "maxBudgetUsd": 15 },
      "plan":       { "maxBudgetUsd": 10 },
      "build":      { "maxBudgetUsd": 50 },
      "verify":     { "maxBudgetUsd": 5 },
      "review":     { "maxBudgetUsd": 10 },
      "review-fix": { "maxBudgetUsd": 30 },
      "ship":       { "maxBudgetUsd": 5 }
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {},
    "stages": ["build", "review"]
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000"
  },
  "watch": {
    "enabled": true
  },
  "decompose": {
    "enabled": false
  }
}
