{
  "quality": {
    "typecheck": "pnpm tsc --noEmit",
    "lint": "pnpm lint",
    "lintFix": "pnpm lint --fix",
    "formatFix": "",
    "testUnit": "pnpm vitest run"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "paths": {
    "taskDir": ".kody/tasks"
  },
  "agent": {
    "modelMap": {
      "cheap": "gemini-2.5-flash",
      "mid": "gemini-2.5-flash",
      "strong": "gemini-3.1-pro"
    },
    "default": {
      "provider": "gemini",
      "model": "gemini-2.5-flash"
    },
    "stages": {
      "taskify": { "provider": "gemini", "model": "gemini-3.1-pro" },
      "plan": { "provider": "gemini", "model": "gemini-3.1-pro" }
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {
      "playwright": {
        "command": "npx",
        "args": ["@anthropic-ai/mcp-server-playwright"]
      }
    },
    "stages": ["build", "verify", "review", "review-fix"],
    "devServer": {
      "command": "pnpm dev",
      "url": "http://localhost:3000"
    }
  },
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json"
}
