{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm tsc --noEmit",
    "lint": "pnpm lint",
    "lintFix": "",
    "formatFix": "",
    "testUnit": "pnpm test"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "agent": {
    "provider": "anthropic",
    "modelMap": {
      "cheap": "claude-haiku-4-5-20251001",
      "mid": "claude-sonnet-4-6",
      "strong": "claude-opus-4-6"
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {},
    "stages": ["build", "review"]
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000"
  },
  "watch": {
    "enabled": true
  }
}
