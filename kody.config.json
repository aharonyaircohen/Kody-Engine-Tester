{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/kody-engine/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm tsc --noEmit",
    "lint": "pnpm lint",
    "lintFix": "",
    "formatFix": "",
    "testUnit": "pnpm test:int"
  },
  "git": {
    "defaultBranch": "dev"
  },
  "defaultExecutable": "classify",
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "state": {
    "repo": "https://github.com/A-Guy-educ/kody-state",
    "path": "Kody-Engine-Tester"
  },
  "agent": {
    "model": "minimax/MiniMax-M2.7-highspeed",
    "modelMap": {
      "cheap": "minimax/MiniMax-M2.7-highspeed",
      "mid": "minimax/MiniMax-M2.7-highspeed",
      "strong": "minimax/MiniMax-M2.7"
    },
    "budgets": {
      "taskify": {
        "maxBudgetUsd": 15
      },
      "plan": {
        "maxBudgetUsd": 10
      },
      "build": {
        "maxBudgetUsd": 50
      },
      "verify": {
        "maxBudgetUsd": 5
      },
      "review": {
        "maxBudgetUsd": 10
      },
      "review-fix": {
        "maxBudgetUsd": 30
      },
      "ship": {
        "maxBudgetUsd": 5
      }
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {},
    "stages": [
      "build",
      "review"
    ]
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000"
  },
  "watch": {
    "enabled": true
  },
  "testRequirements": [
    {
      "pattern": "src/app/api/**/route.ts",
      "requireSibling": "{name}.test{ext}"
    }
  ],
  "release": {
    "releaseBranch": "main"
  },
  "company": {
    "activeGoals": [
      "live-agent-loop-model-20260622061708",
      "ci-health",
      "prs-stay-mergeable"
    ]
  }
}
