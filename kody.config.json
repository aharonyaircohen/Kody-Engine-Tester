{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm tsc --noEmit",
    "lint": "pnpm lint",
    "lintFix": "",
    "formatFix": "",
    "testUnit": "pnpm test"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "agent": {
    "provider": "minimax",
    "modelMap": {
      "cheap": "MiniMax-M2.7-highspeed",
      "mid": "MiniMax-M2.7-highspeed",
      "strong": "MiniMax-M2.7-highspeed"
    }
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000"
  },
  "mcp": {
    "enabled": true,
    "servers": {
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"],
        "env": {}
      }
    },
    "stages": ["build", "verify", "review", "review-fix"]
  },
  "watch": {
    "enabled": true,
    "activityLog": 369,
    "model": "MiniMax-M2.7-highspeed",
    "provider": "minimax"
  }
}
