{
  "quality": {
    "typecheck": "",
    "lint": "pnpm lint",
    "lintFix": "",
    "format": "",
    "formatFix": "",
    "testUnit": "pnpm test:int"
  },
  "git": {
    "defaultBranch": "kody"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "paths": {
    "taskDir": ".tasks"
  },
  "agent": {
    "runner": "claude-code",
    "defaultRunner": "claude",
    "litellmUrl": "http://localhost:4000",
    "modelMap": {
      "cheap": "claude-haiku-4-5",
      "mid": "claude-sonnet-4-6",
      "strong": "claude-sonnet-4-6"
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {
      "playwright": {
        "command": "npx",
        "args": ["@playwright/mcp@latest", "--no-sandbox"]
      }
    },
    "stages": ["build", "review"],
    "devServer": {
      "command": "pnpm dev",
      "url": "http://localhost:3000",
      "readyPattern": "Ready in"
    }
  },
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json"
}
