{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm tsc --noEmit",
    "lint": "pnpm lint",
    "lintFix": "",
    "formatFix": "",
    "testUnit": "pnpm test:int"
  },
  "git": {
    "defaultBranch": "dev"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Engine-Tester"
  },
  "agent": {
    "model": "minimax/MiniMax-M3",
    "modelMap": {
      "cheap": "minimax/MiniMax-M3",
      "mid": "minimax/MiniMax-M3",
      "strong": "minimax/MiniMax-M3"
    },
    "budgets": {
      "taskify": {
        "maxBudgetUsd": 15
      },
      "plan": {
        "maxBudgetUsd": 10
      },
      "build": {
        "maxBudgetUsd": 50
      },
      "verify": {
        "maxBudgetUsd": 5
      },
      "review": {
        "maxBudgetUsd": 10
      },
      "review-fix": {
        "maxBudgetUsd": 30
      },
      "ship": {
        "maxBudgetUsd": 5
      }
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {},
    "stages": [
      "build",
      "review"
    ]
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000"
  },
  "watch": {
    "enabled": true
  },
  "testRequirements": [
    {
      "pattern": "src/app/api/**/route.ts",
      "requireSibling": "{name}.test{ext}"
    }
  ],
  "release": {
    "releaseBranch": "main"
  }
}
